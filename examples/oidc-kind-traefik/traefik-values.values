# Traefik Helm chart values for OIDC plugin demo
experimental:
  plugins:
    traefik-oidc-auth:
      moduleName: github.com/sevensolutions/traefik-oidc-auth
      version: v0.19.0

service:
  type: NodePort

ports:
  web:
    nodePort: 30080

providers:
  kubernetesCRD:
    enabled: true
    allowCrossNamespace: true
