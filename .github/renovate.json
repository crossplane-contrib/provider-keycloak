{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "labels": [
    "renovatebot",
    "dependencies"
  ],
  "extends": [
    "config:recommended",
    ":semanticCommits",
    "helpers:pinGitHubActionDigests",
    ":automergeRequireAllStatusChecks"
  ],
  "baseBranches": [
    "main"
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "dependencyDashboard": true,
  "recreateWhen": "always",
  "platformAutomerge": true,
  "ignoreDeps": [
    "github.com/keycloak/terraform-provider-keycloak",
    "keycloak/terraform-provider-keycloak"
  ],
  "packageRules": [
    {
      "groupName": "k8s.io dependencies",
      "matchManagers": [
        "gomod"
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "digest"
      ],
      "automerge": true,
      "matchPackageNames": [
        "/^k8s\\.io//"
      ]
    },
    {
      "groupName": "sigs.k8s.io dependencies",
      "matchManagers": [
        "gomod"
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "digest"
      ],
      "automerge": true,
      "matchPackageNames": [
        "/^sigs\\.k8s\\.io//"
      ]
    },
    {
      "groupName": "github.com/keycloak/terraform-provider-keycloak dependencies",
      "matchManagers": [
        "gomod"
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "digest"
      ],
      "automerge": true,
      "matchPackageNames": [
        "/^github\\.com/keycloak/terraform-provider-keycloak/"
      ]
    },
    {
      "groupName": "github.com/hashicorp dependencies",
      "matchManagers": [
        "gomod"
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "digest"
      ],
      "automerge": true,
      "matchPackageNames": [
        "/^github\\.com/hashicorp//"
      ]
    },
    {
      "groupName": "github.com/crossplane dependencies",
      "matchManagers": [
        "gomod"
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "digest"
      ],
      "automerge": true,
      "matchPackageNames": [
        "/^github\\.com/crossplane//"
      ]
    },
    {
      "groupName": "github.com/alecthomas dependencies",
      "matchManagers": [
        "gomod"
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "digest"
      ],
      "automerge": true,
      "matchPackageNames": [
        "/^github\\.com/alecthomas//"
      ]
    },
    {
      "groupName": "github-actions",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "digest"
      ],
      "automerge": true
    },
    {
      "description": "Terraform 1.6+ is not allowed due to BSL licensing",
      "matchDepNames": [
        "hashicorp/terraform"
      ],
      "allowedVersions": "<1.6.0"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "^Makefile$"
      ],
      "matchStrings": [
        "export TERRAFORM_PROVIDER_VERSION .*= (?<currentValue>.*)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "keycloak/terraform-provider-keycloak",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^Makefile$"
      ],
      "matchStrings": [
        "export TERRAFORM_VERSION \\?= (?<currentValue>.*)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "hashicorp/terraform",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^Makefile$"
      ],
      "matchStrings": [
        "export GOLANGCILINT_VERSION \\?= (?<currentValue>.*)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "golangci/golangci-lint",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^Makefile$"
      ],
      "matchStrings": [
        "KUBECTL_VERSION \\?= (?<currentValue>.*)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "kubernetes/kubernetes",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^Makefile$"
      ],
      "matchStrings": [
        "KIND_VERSION = (?<currentValue>.*)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "kubernetes-sigs/kind",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^Makefile$"
      ],
      "matchStrings": [
        "UP_VERSION = (?<currentValue>.*)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "upbound/up",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^Makefile$"
      ],
      "matchStrings": [
        "UPTEST_VERSION = (?<currentValue>.*)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "crossplane-contrib/uptest",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^Makefile$"
      ],
      "matchStrings": [
        "CHAINSAW_VERSION = (?<currentValue>.*)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "kyverno/chainsaw",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^Makefile$"
      ],
      "matchStrings": [
        "CROSSPLANE_VERSION = (?<currentValue>.*)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "crossplane/crossplane",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^Makefile$"
      ],
      "matchStrings": [
        "CROSSPLANE_CLI_VERSION = (?<currentValue>.*)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "crossplane/crossplane",
      "versioningTemplate": "semver"
    }
  ]
}
